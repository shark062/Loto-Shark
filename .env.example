# ─────────────────────────────────────────────────────────────────────────────
# Loto-Shark — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com suas chaves reais.
# NUNCA faça commit do arquivo .env — ele está no .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provedores de IA ─────────────────────────────────────────────────────────
# Pelo menos um provedor deve estar configurado para usar as funcionalidades de IA.

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sua_chave_aqui

# Anthropic / Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sua_chave_aqui

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=sua_chave_aqui

# Groq — LLaMA ultrarrápido (https://console.groq.com/keys)
GROQ_API_KEY=sua_chave_aqui

# DeepSeek (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sua_chave_aqui

# OpenRouter — acesso a múltiplos modelos (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sua_chave_aqui

# Mistral AI (https://console.mistral.ai/)
MISTRAL_API_KEY=sua_chave_aqui

# Cohere (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=sua_chave_aqui
